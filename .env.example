DJANGO_SETTINGS_MODULE=printverse.settings.dev
SECRET_KEY=change-me-in-prod
DEBUG=True
ALLOWED_HOSTS=*

# Database
DATABASE_URL=postgres://printverse:printverse@localhost:5432/printverse

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AWS S3
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=printverse-media
AWS_S3_REGION_NAME=ap-south-1

# Social auth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# FCM
FCM_CREDENTIALS_JSON=

# Commission default
DEFAULT_COMMISSION_PERCENT=15

